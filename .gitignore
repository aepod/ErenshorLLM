Cargo.lock

# C# / .NET
bin/
obj/
*.dll
*.pdb
*.user
*.suo
.vs/

# Models (too large for git)
*.gguf
*.onnx
sidecar/data/models/

# Vector databases (built at compile/runtime)
*.ruvector
sidecar/data/dist/
