!sidecar/data/dist/personality.ruvector
!sidecar/data/dist/responses.ruvector
!sidecar/data/dist/lore.ruvector

# ONNX Runtime shared libs
sidecar/data/lib/

# Shimmy binary (downloaded during build)
sidecar/shimmy.exe

# Vulkan SDK (cross-compile dependency, too large for git)
sidecar/vulkan-sdk-mingw/

# RVF runtime data (built or generated)
memory.rvf

