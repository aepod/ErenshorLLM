      "priority": 1.5,
      "sim_name": "Liii"
    },
    {
      "id": "liii_003",
      "text": "Pro tip, {player}: always call dibs before the pull. If you don't claim it first, someone better will. Someone like me.",
      "context_tags": ["faction", "friends_club", "condescending", "advice"],
      "zone_affinity": [],
