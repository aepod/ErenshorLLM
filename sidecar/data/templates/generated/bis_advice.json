      "zone_affinity": ["Braxonian Desert"],
      "personality_affinity": ["helpful"],
      "relationship_min": 0.0,
      "relationship_max": 10.0,
      "channel": ["say"],
      "priority": 1.1
    },
    {
      "id": "bis_advice_042",
      "text": "Terra Crown from Nipper King in Abyssal Lake is bizarre. CHA plus 35, MR plus 5 percent, PR plus 5 percent. Dual resists on a head slot. Every class can use it.",
