      "context_tags": ["gear", "advice", "class", "leveling"],
      "zone_affinity": ["Stowaway's Step", "The Bone Pits", "Vitheo's Watch"],
      "personality_affinity": ["helpful", "friendly"],
      "relationship_min": 0.0,
      "relationship_max": 10.0,
      "channel": ["say"],
      "priority": 1.1
